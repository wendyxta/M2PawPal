classDiagram
    class Owner {
        +str name
        +list pets
        +addPet(pet) None
        +removePet(pet) None
        +getPets() list
        +getTasksByPet(date, pet_name) list
        +getAllTasksForDate(date) list
        +checkConflicts(date) list
    }

    class Pet {
        +str name
        +Owner owner
        +str healthNotes
        +dict schedulers
        +getOwner() Owner
        +getTasks() list
        +getSchedule(date) TaskScheduler
        +addTask(task) None
        +removeTask(task) None
    }

    class Task {
        +str title
        +time time
        +int priority
        +str status
        +str recurrence
        +complete() None
        +isComplete() bool
    }

    class TaskScheduler {
        +Pet pet
        +str date
        +list tasks
        +addTask(task) None
        +completeTask(task) None
        +getTasksByTime() list
        +getPendingTasks() list
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" TaskScheduler : schedules via
    TaskScheduler "*" --> "*" Task : manages
